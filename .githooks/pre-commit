#!/bin/sh
#
# Pre-commit hook: lint, format check, typecheck, and test
# Prevents commits that would fail CI.

set -e

echo "==> Running lint..."
npm run lint

echo "==> Checking formatting..."
npm run format:check

echo "==> Typechecking..."
npm run typecheck

echo "==> Running tests..."
npm run test

echo "==> All checks passed!"
