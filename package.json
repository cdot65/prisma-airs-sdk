{
  "name": "@cdot65/prisma-airs-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for Palo Alto Networks AI Runtime Security",
  "author": "Calvin Remsburg <cremsburg.dev@gmail.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cdot65/prisma-airs-sdk.git"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai runtime security",
    "palo alto networks",
    "airs",
    "security",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "git config core.hooksPath .githooks && npm run build",
    "prepublishOnly": "npm run lint && npm run test",
    "example:scan": "npx tsx --env-file=.env examples/basic-scan.ts",
    "example:async-scan": "npx tsx --env-file=.env examples/async-scan.ts",
    "example:query": "npx tsx --env-file=.env examples/query-results.ts",
    "example:mgmt-auth": "npx tsx --env-file=.env examples/mgmt-auth.ts",
    "example:mgmt-profiles": "npx tsx --env-file=.env examples/mgmt-profiles.ts",
    "example:mgmt-topics": "npx tsx --env-file=.env examples/mgmt-topics.ts"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "prettier": "^3.8.1",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
